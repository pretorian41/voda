
{% extends 'base.html.twig' %}

{% block body %}
    <!-- HERO -->
    <div class="relative">



        <!-- Burger -->
        <button class="absolute top-4 right-4 text-sky-800">
            ☰
        </button>
    </div>

    <!-- CONTENT -->
    <div class="px-5 py-6 text-left">
        <h1 class="px-5 text-[26px] font-semibold text-sky-900 leading-tight mb-4">
            Доставка води<br>по Коцюбинському
        </h1>

        <!-- Price -->
        <div class="px-5 flex items-start gap-2 mb-3">
            <span class="text-xl">💧</span>
            <p class="text-sky-900">
                Вартість 1 бутля<br>
                з доставкою —
                <span class="font-semibold">100 грн</span>
            </p>
        </div>

        <!-- Delivery time -->
        <div class="px-5 flex items-start gap-2 mb-5">
            <span class="text-xl">🚚</span>
            <p class="text-sky-900">
                Доставка щодня<br>
                з понеділка по пʼятницю
            </p>
        </div>
        {{ form_start(form, {
            attr: { class: 'space-y-3' }
        }) }}

        {{ form_widget(form.website) }}
        {% for field in form %}
            {% if  field.vars.name not  in ['_token', 'website'] %}

                {% set hasError = field.vars.errors|length > 0 %}

                {{ form_widget(field, {
                    attr: {
                        class: '
                    w-full
                    rounded-2xl
                    border-2
                    bg-white
                    px-4 py-3
                    text-sky-900
                    placeholder-sky-400
                    shadow-sm
                    focus:outline-none
                    focus:ring-4
                    transition
                    ' ~ (
                        hasError
                        ? 'border-red-400 focus:border-red-500 focus:ring-red-200'
                        : 'border-sky-200 focus:border-sky-500 focus:ring-sky-200'
                        )
                    }
                }) }}

                {% for error in field.vars.errors %}
                    <p class="mt-1 text-sm text-red-600 font-medium">
                        {{ error.message }}
                    </p>
                {% endfor %}
            {% endif %}
        {% endfor %}
        <button
            type="submit"
            class="w-full py-4 rounded-2xl text-lg font-medium text-white
   bg-gradient-to-b from-sky-400 to-sky-600
   hover:opacity-90 transition">
            Замовити воду
        </button>

        {{ form_end(form) }}

    </div>


    <section class="px-5 py-8 text-slate-700 text-sm leading-relaxed space-y-4">
        <p>
            <strong>Коцюбинська вода</strong> — це швидка та зручна
            <strong>доставка питної води у Коцюбинському</strong>.
            Ми працюємо у передмісті Києва та доставляємо воду
            у житлові будинки, офіси.
        </p>

        <p>
            Пропонуємо очищену питну воду у бутлях 19 літрів.
            Вартість одного бутля з доставкою —
            <strong>100 грн</strong>.
            Доставка здійснюється з понеділка по пʼятницю.
        </p>

        <p>
            Якщо вам потрібна
            <strong>доставка води у Коцюбинському без дзвінків</strong>,
            просто залиште заявку на сайті —
            ми швидко опрацюємо замовлення.
        </p>
    </section>
{% endblock %}
